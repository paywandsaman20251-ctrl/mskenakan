<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>مسکێنەکان</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body<% if (currentUser) { %> data-username="<%= currentUser.username %>"<% } %>>
    <main class="page">
      <nav class="navbar card">
        <a class="brand" href="/">مسکێنەکان</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <% if (currentUser) { %>
          <a href="/community">Community</a>
          <a href="/truth-or-dare">Truth or Dare</a>
          <% if (currentUser.role === "admin") { %>
          <a href="/admin">Admin Panel</a>
          <% } %>
          <form action="/logout" method="post"><button type="submit">Logout</button></form>
          <% } else { %>
          <a href="/login">Login</a>
          <a href="/register">Register</a>
          <% } %>
        </div>
      </nav>

      <header class="hero">
        <h1 class="hero-title">مسکێنەکان</h1>
        <p class="subtitle" dir="rtl" lang="ku">
          مسکێنەکان رێزی گەورەکانتان بگرن
        </p>
      </header>

      <section class="card role-card">
        <h2>Top of the page: Shex & Baag 👑</h2>
        <div class="members">
          <% if (topMembers.length === 0) { %>
          <p class="empty">No top members found yet.</p>
          <% } %>
          <% topMembers.forEach(function(member) { %>
          <figure class="member">
            <% if (member.imageUrl) { %>
            <img
              class="member-photo"
              src="<%= normalizeImageUrl(member.imageUrl) %>"
              alt="<%= member.name %>"
              loading="lazy"
            />
            <% } else { %>
            <div class="no-image">No image</div>
            <% } %>
            <% if (member.imageText) { %>
            <div class="image-text"><%= member.imageText %></div>
            <% } %>
            <figcaption>
              <strong><%= member.name %></strong>
              <span><%= member.role %></span>
            </figcaption>
          </figure>
          <% }); %>
        </div>
      </section>

      <section class="card role-card">
        <h2>Bottom of the page: Mskenms ⚔️</h2>
        <div class="members">
          <% if (bottomMskenms.length === 0) { %>
          <p class="empty">No msken members yet.</p>
          <% } %>
          <% bottomMskenms.forEach(function(member) { %>
          <figure class="member">
            <% if (member.imageUrl) { %>
            <img
              class="member-photo"
              src="<%= normalizeImageUrl(member.imageUrl) %>"
              alt="<%= member.name %>"
              loading="lazy"
            />
            <% } else { %>
            <div class="no-image">No image</div>
            <% } %>
            <% if (member.imageText) { %>
            <div class="image-text"><%= member.imageText %></div>
            <% } %>
            <figcaption>
              <strong><%= member.name %></strong>
              <span><%= member.role %></span>
            </figcaption>
          </figure>
          <% }); %>
        </div>
      </section>
    </main>

    <div id="photo-lightbox" class="photo-lightbox" hidden role="dialog" aria-modal="true" aria-label="Full screen photo">
      <button type="button" class="photo-lightbox-close" aria-label="Close full screen">&times;</button>
      <img class="photo-lightbox-img" src="" alt="" />
    </div>

    <script>
      (function () {
        var lb = document.getElementById("photo-lightbox");
        if (!lb) return;
        var lbImg = lb.querySelector(".photo-lightbox-img");
        var closeBtn = lb.querySelector(".photo-lightbox-close");

        function openLightbox(src, alt) {
          lbImg.src = src;
          lbImg.alt = alt || "";
          lb.hidden = false;
          document.body.style.overflow = "hidden";
        }

        function closeLightbox() {
          lb.hidden = true;
          lbImg.removeAttribute("src");
          lbImg.alt = "";
          document.body.style.overflow = "";
        }

        document.querySelectorAll(".member-photo").forEach(function (img) {
          img.addEventListener("click", function () {
            openLightbox(img.currentSrc || img.src, img.alt);
          });
        });

        lb.addEventListener("click", function (e) {
          if (e.target === lbImg) return;
          closeLightbox();
        });

        closeBtn.addEventListener("click", function (e) {
          e.stopPropagation();
          closeLightbox();
        });

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && !lb.hidden) closeLightbox();
        });
      })();
    </script>
    <% if (currentUser) { %>
    <script src="/community-notify.js" defer></script>
    <% } %>
  </body>
</html>
