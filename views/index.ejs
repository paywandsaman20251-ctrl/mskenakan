<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>مسکێنەکان</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page">
      <nav class="navbar card">
        <a class="brand" href="/">مسکێنەکان</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <% if (currentUser) { %>
          <a href="/community">Community</a>
          <% if (currentUser.role === "admin") { %>
          <a href="/admin/users">Verify Users</a>
          <% } %>
          <form action="/logout" method="post"><button type="submit">Logout</button></form>
          <% } else { %>
          <a href="/login">Login</a>
          <a href="/register">Register</a>
          <% } %>
        </div>
      </nav>

      <header class="hero">
        <p class="badge">🤣 Coolest Friend Group Ever</p>
        <h1 class="hero-title">مسکێنەکان</h1>
        <p class="subtitle">
          Shex and Baag rule the kingdom with maximum drama. Msken and the Mskenms
          are on mission mode. Add your funniest members using ImgBB links.
        </p>
        <p class="joke-line">Warning: Too much style may cause legendary friendship energy.</p>
      </header>

      <section class="card role-card">
        <h2>Top of the page: Shex & Baag 👑</h2>
        <div class="members">
          <% if (topMembers.length === 0) { %>
          <p class="empty">No top members found yet.</p>
          <% } %>
          <% topMembers.forEach(function(member) { %>
          <figure class="member">
            <% if (member.imageUrl) { %>
            <img src="<%= member.imageUrl %>" alt="<%= member.name %>" loading="lazy" />
            <% } else { %>
            <div class="no-image">No image</div>
            <% } %>
            <% if (member.imageText) { %>
            <div class="image-text"><%= member.imageText %></div>
            <% } %>
            <figcaption>
              <strong><%= member.name %></strong>
              <span><%= member.role %></span>
              <% if (currentUser && currentUser.role === "admin") { %>
              <form action="/members/<%= member._id %>/update" method="post" class="mini-form">
                <input name="name" type="text" value="<%= member.name %>" required />
                <select name="role">
                  <% roles.forEach(function(role) { %>
                  <option value="<%= role %>" <%= member.role === role ? "selected" : "" %>>
                    <%= role.toUpperCase() %>
                  </option>
                  <% }); %>
                </select>
                <input name="imageUrl" type="url" value="<%= member.imageUrl %>" placeholder="Image URL" />
                <input name="imageText" type="text" value="<%= member.imageText || "" %>" placeholder="Write on image" />
                <button type="submit">Save</button>
              </form>
              <form action="/members/<%= member._id %>/remove-image" method="post">
                <button type="submit">Remove Image</button>
              </form>
              <form action="/members/<%= member._id %>/delete" method="post">
                <button type="submit">Delete Card</button>
              </form>
              <% } %>
            </figcaption>
          </figure>
          <% }); %>
        </div>
      </section>

      <section class="card role-card">
        <h2>Bottom of the page: Mskenms ⚔️</h2>
        <div class="members">
          <% if (bottomMskenms.length === 0) { %>
          <p class="empty">No msken members yet.</p>
          <% } %>
          <% bottomMskenms.forEach(function(member) { %>
          <figure class="member">
            <% if (member.imageUrl) { %>
            <img src="<%= member.imageUrl %>" alt="<%= member.name %>" loading="lazy" />
            <% } else { %>
            <div class="no-image">No image</div>
            <% } %>
            <% if (member.imageText) { %>
            <div class="image-text"><%= member.imageText %></div>
            <% } %>
            <figcaption>
              <strong><%= member.name %></strong>
              <span><%= member.role %></span>
              <% if (currentUser && currentUser.role === "admin") { %>
              <form action="/members/<%= member._id %>/update" method="post" class="mini-form">
                <input name="name" type="text" value="<%= member.name %>" required />
                <select name="role">
                  <% roles.forEach(function(role) { %>
                  <option value="<%= role %>" <%= member.role === role ? "selected" : "" %>>
                    <%= role.toUpperCase() %>
                  </option>
                  <% }); %>
                </select>
                <input name="imageUrl" type="url" value="<%= member.imageUrl %>" placeholder="Image URL" />
                <input name="imageText" type="text" value="<%= member.imageText || "" %>" placeholder="Write on image" />
                <button type="submit">Save</button>
              </form>
              <form action="/members/<%= member._id %>/remove-image" method="post">
                <button type="submit">Remove Image</button>
              </form>
              <form action="/members/<%= member._id %>/delete" method="post">
                <button type="submit">Delete Card</button>
              </form>
              <% } %>
            </figcaption>
          </figure>
          <% }); %>
        </div>
      </section>

      <% if (currentUser && currentUser.role === "admin") { %>
      <section class="card form-card">
        <h2>Admin: Add Member Photo</h2>
        <form action="/members" method="post" class="form">
          <label>
            Name
            <input required name="name" type="text" placeholder="Example: New Msken" />
          </label>
          <label>
            Role
            <select name="role">
              <% roles.forEach(function(role) { %>
              <option value="<%= role %>"><%= role.toUpperCase() %></option>
              <% }); %>
            </select>
          </label>
          <label>
            Image URL (ImgBB)
            <input required name="imageUrl" type="url" placeholder="https://i.ibb.co/..." />
          </label>
          <label>
            Text on Image
            <input name="imageText" type="text" placeholder="Example: BAG BOSS" />
          </label>
          <button type="submit">Add Photo</button>
        </form>
      </section>
      <% } %>
    </main>
  </body>
</html>
