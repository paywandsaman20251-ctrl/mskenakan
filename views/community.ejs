<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Community | مسکێنەکان</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body<% if (currentUser) { %> data-username="<%= currentUser.username %>"<% } %>>
    <main class="page">
      <nav class="navbar card">
        <a class="brand" href="/">مسکێنەکان</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/community">Community</a>
          <a href="/truth-or-dare">Truth or Dare</a>
          <% if (currentUser && currentUser.role === "admin") { %>
          <a href="/admin">Admin Panel</a>
          <% } %>
          <form action="/logout" method="post"><button type="submit">Logout</button></form>
        </div>
      </nav>

      <section class="card form-card">
        <h2>Community Feed</h2>
        <p class="subtitle">Post text and an optional image. Files are saved on this server as <strong>/uploads/…</strong> so every device loads them from the same site. If you use “image link”, paste a normal https URL (not a localhost address from your browser).</p>
        <form class="form" action="/community/posts" method="post" enctype="multipart/form-data">
          <label>
            Post text
            <textarea name="text" required maxlength="500" rows="4"></textarea>
          </label>
          <label>
            Image from your device (optional)
            <input name="image" type="file" accept="image/jpeg,image/png,image/gif,image/webp" />
          </label>
          <label>
            Or image link (optional, http/https)
            <input name="imageUrl" type="url" placeholder="https://..." />
          </label>
          <button type="submit">Post</button>
        </form>
      </section>

      <section class="grid">
        <% posts.forEach(function(post) { %>
        <article class="card community-post <%= post.authorName === todBotName ? 'tod-bot-post' : '' %>">
          <header class="post-header">
            <p class="post-author"><strong>@<%= post.authorName %></strong></p>
            <% if (currentUser && currentUser.role === "admin") { %>
            <form action="/community/posts/<%= post._id %>/delete" method="post" class="post-delete-form">
              <button type="submit" class="btn-delete">Delete</button>
            </form>
            <% } %>
          </header>
          <p class="<%= post.authorName === todBotName ? 'tod-bot-text' : '' %>"><%= post.text %></p>
          <% if (post.imageUrl) { %>
          <img class="community-image" src="<%= normalizeImageUrl(post.imageUrl) %>" alt="Post image" />
          <% } %>
        </article>
        <% }); %>
      </section>
    </main>
    <% if (currentUser) { %>
    <script src="/community-notify.js" defer></script>
    <% } %>
  </body>
</html>
